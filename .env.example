# Lead Crawler Configuration
# Copy this file to .env and adjust values

# === Ollama LLM Settings ===
OLLAMA_URL=http://192.168.178.123:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_DELAY=1.0

# === Cache Settings ===
CACHE_DB_PATH=data/analysis_cache.db
CACHE_TTL_DAYS=30
CACHE_MAX_ENTRIES=100000
CACHE_CLEANUP_HOURS=24

# === PLZ Database ===
PLZ_DB_PATH=data/plz_austria.db
PLZ_DEFAULT_RADIUS=20.0
PLZ_MAX_RADIUS=100.0

# === Crawler Settings ===
CRAWLER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
CRAWLER_RATE_LIMIT=2.0
CRAWLER_CONCURRENT=1
CRAWLER_TIMEOUT=30
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_MAX_RETRIES=3
CRAWLER_RETRY_DELAY=5.0

# === WKO Spider ===
WKO_BASE_URL=https://firmen.wko.at
WKO_TIMEOUT=30

# === Website Crawler ===
WEBSITE_TIMEOUT=15
WEBSITE_MAX_WORDS=800
WEBSITE_DELAY=1.0

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_KEY_HEADER=X-API-Key
# Comma-separated API keys for authentication
# API_KEYS=key1,key2,key3
# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# === Project Paths ===
DATA_DIR=data
OUTPUT_DIR=output

# === Default Values ===
DEFAULT_PLZ=2351
DEFAULT_RADIUS=20.0